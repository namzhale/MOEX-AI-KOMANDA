# Локальная разработка через `docker compose up`. На проде эти же переменные
# приходят либо из k8s-секрета (только два ключа), либо из Dockerfile ENV.
#
# MOEX ISS API ключа не требует.

# --- Секреты -----------------------------------------------------------------
# ArenaGo: токен из профиля https://arenago.ru, кнопка "Generate New Token".
# В заголовке Authorization идёт как есть, без префикса Bearer.
SANDBOX_API_KEY=<placeholder>

# LLM-шлюз. Имя переменной — POLZA_API_KEY, потому что чарт организаторов
# инжектит секрет под этим именем. Значение внутри — наш polza.ai-ключ (оба
# шлюза OpenAI-совместимы, ходим в polza, см. LLM_BASE_URL).
POLZA_API_KEY=<placeholder>

# --- Конфиг (на проде задаётся через Dockerfile ENV) -------------------------
ARENAGO_BASE_URL=https://arenago.ru
ARENAGO_BOT=Команда

LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
POLZA_BALANCE_FAILSAFE_ENABLED=true
POLZA_BALANCE_MIN_RUB=0.01
POLZA_BALANCE_GRACE_MINUTES=30
POLZA_BALANCE_TIMEOUT_SECONDS=5.0

# DRY_RUN=true — ордера НЕ отправляются (только лог). Снимаем только когда
# уверены в стратегии (точно не на Этапе 1).
DRY_RUN=true
LOG_LEVEL=INFO
# console — цветной dev-формат с выровненными колонками (только локально).
# В Dockerfile ENV дефолт уже json — для kubectl logs / Loki в k8s.
# Здесь явно ставим console, чтобы `docker compose up` показывал читаемые логи.
LOG_FORMAT=console
DATA_DIR=/data

# --- Автономный цикл ---------------------------------------------------------
AGENT_ENABLED=true
# Период тика в минутах. На 30 → ~17 тиков/торговый день → ~13 ₽/день на gpt-4o-mini.
AGENT_TICK_MINUTES=20
# Размер свечи. 10 мин: фетчер algopack пагинирует.
AGENT_INTERVAL=10
# Окно свечей (календ. дни). 14 дн × 10-мин ≈ 520 баров (>> MIN_BARS=50).
AGENT_CANDLE_DAYS=14
# Тикеры через запятую. Пусто = универс по умолчанию (19 акций конкурса).
# Для первого теста удобно один: AGENT_TICKERS=SBER
AGENT_TICKERS=
MARKET_CONTEXT_ENABLED=true
MARKET_CONTEXT_FAST_MINUTES=60
MARKET_CONTEXT_MID_MINUTES=240
MARKET_CONTEXT_RETURN_THRESHOLD=0.0025
MARKET_CONTEXT_REVERSAL_THRESHOLD=0.002
MARKET_CONTEXT_BULLISH_BREADTH=0.55
MARKET_CONTEXT_BEARISH_BREADTH=0.45

# --- Экономия токенов (см. IMPLEMENTATION.md) ---------------------------
AGENT_PREFILTER_ENABLED=true
AGENT_EARLY_EXIT_ENABLED=true
# Пороги под 10-мин (мельче, чем дефолты 60-мин 42/58/0.15/0.008).
AGENT_PREFILTER_RSI_LOW=45
AGENT_PREFILTER_RSI_HIGH=55
AGENT_PREFILTER_MACD_HIST_MAX=0.05
AGENT_PREFILTER_EMA_SPREAD_MAX=0.003
# 0.25 под 10-мин (было 0.35): меньше режем flat-сетапы до EV-трейдера.
AGENT_EARLY_EXIT_MAX_CONFIDENCE=0.25

# --- Reflection (фаза 0: JSONL в DATA_DIR/reflections.jsonl) ------------
REFLECTION_ENABLED=true
REFLECTION_IN_GRAPH=false
META_REFLECTION_ENABLED=false

# FinMem-style ranking в Qdrant (α·sim + β·recency + γ·importance)
MEMORY_SCORE_ALPHA=0.5
MEMORY_SCORE_BETA=0.3
MEMORY_SCORE_GAMMA=0.2

# HTTP API (кусок 9): защита POST /scheduler/tick
# Пусто → ручка отключена (503). Локально: API_TOKEN=dev-secret
API_TOKEN=

# Qdrant (кусок 10): docker compose up поднимает qdrant на :6333
QDRANT_ENABLED=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=team24_reflections
EMBEDDING_MODEL=openai/text-embedding-3-small

# Dynamic universe (кусок 12): 0 = все 19 тикеров; 8 = LLM только по 8 за тик
AGENT_LLM_TICKERS_PER_TICK=8

# --- Short-check (one-shot S→B на ArenaGo) -----------------------------------
# Запуск: python -m agent.runtime.short_check_main
# Compose: docker compose --profile short-check up short-check
SHORT_CHECK_SECID=AUTO
SHORT_CHECK_CANDIDATES=
SHORT_CHECK_QUANTITY=1
SHORT_CHECK_DELAY_SECONDS=300

# Webhook (структурированные события + structlog)
WEBHOOK_SOURCE=team-24
# LOG_WEBHOOK_URL=https://webhook.site/your-id

# Расписание:
#   false (дефолт) — торгуем всегда, пока ArenaGo открыт (00:00–23:50 MSK любой день).
#   true           — только основная сессия MOEX (10:00–18:39 MSK, пн–пт).
# Включай true только если хочешь экономить LLM-токены в выходные и вечером.
AGENT_RESPECT_MOEX_HOURS=false

# --- MOEX Algopack (тариф Promo: online + Super Candles) --------------------
# Подробно: CHANGELOG_ALGOPACK.md
MARKET_DATA_SOURCE=algopack
ALGOPACK_TOKEN=<JWT из https://data.moex.com/personal-account>
ALGOPACK_BASE_URL=https://apim.moex.com/iss
# 10-мин (фетчер пагинирует — см. выше).
AGENT_INTERVAL=10

ALGOPACK_FLOW_ENABLED=true
ALGOPACK_ORDERSTATS_ENABLED=false
ALGOPACK_MEGA_ALERT_ENABLED=true
ALGOPACK_MEGA_ALERT_SKIP=true
ALGOPACK_UNIVERSE_LIQUIDITY_RANK=true
ALGOPACK_PREFILTER_DISB_ABS_MAX=0.15
# Спреды MOEX в базисных пунктах (bps). SBER ~2 bps.
ALGOPACK_PREFILTER_SPREAD_1MIO_MAX_BPS=50
RISK_EDGE_VOL_MULT=3.0
ALGOPACK_RISK_SPREAD_1MIO_MAX_BPS=80

# Ручной тик scheduler (локально)
# Profit-lock is implemented but kept off until activity checks confirm it does
# not reduce exposure/turnover too much.
RISK_PROFIT_TAKE_ENABLED=false
RISK_PROFIT_LOCK_PCT=0.007
RISK_PROFIT_PARTIAL_PCT=0.012
RISK_PROFIT_FULL_PCT=0.020
RISK_PROFIT_LOCK_FRACTION=0.50
RISK_PROFIT_PARTIAL_FRACTION=0.50

API_TOKEN=dev-secret
