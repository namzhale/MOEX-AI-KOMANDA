# Safe by default: no real orders are sent while DRY_RUN=true.
DRY_RUN=true

# Arenago trading API.
ARENAGO_API_BASE_URL=https://arenago.ru
ARENAGO_API_KEY=

# Polza model aggregator API.
POLZA_API_KEY=

# Platform deployment may provide the ArenaGo key as SANDBOX_API_KEY.
SANDBOX_API_KEY=

# Bot identity and trading target.
BOT_NAME=Team24ArenaBot
SECID=SBER
ORDER_QUANTITY=1

# One decision every 12 hours.
INTERVAL_HOURS=12
ERROR_SLEEP_SECONDS=900
STATE_PATH=/data/state.json
LOG_FILE=/data/bot.log
LOG_WEBHOOK_URL=
LOOP_FOREVER=true
